{"ast":null,"code":"import React,{createContext,useContext,useEffect,useMemo,useState}from'react';import{io}from'socket.io-client';import{toast}from'react-toastify';import{useAuth}from'./AuthContext';import{jsx as _jsx}from\"react/jsx-runtime\";const NotificationContext=/*#__PURE__*/createContext();export const NotificationProvider=_ref=>{let{children}=_ref;const{user}=useAuth();const[notifications,setNotifications]=useState([]);useEffect(()=>{if(!user||user.role==='customer'){setNotifications([]);return undefined;}const socket=io(process.env.REACT_APP_SOCKET_URL||'http://localhost:5000',{transports:['websocket','polling']});socket.on('notification',payload=>{const item={id:`${Date.now()}-${Math.random().toString(36).slice(2,7)}`,read:false,...payload};setNotifications(prev=>[item,...prev].slice(0,30));toast.info(payload.title||'New notification');});return()=>socket.disconnect();},[user]);const unreadCount=useMemo(()=>notifications.filter(item=>!item.read).length,[notifications]);const markAllRead=()=>setNotifications(prev=>prev.map(item=>({...item,read:true})));return/*#__PURE__*/_jsx(NotificationContext.Provider,{value:{notifications,unreadCount,markAllRead},children:children});};export const useNotifications=()=>useContext(NotificationContext);","map":{"version":3,"names":["React","createContext","useContext","useEffect","useMemo","useState","io","toast","useAuth","jsx","_jsx","NotificationContext","NotificationProvider","_ref","children","user","notifications","setNotifications","role","undefined","socket","process","env","REACT_APP_SOCKET_URL","transports","on","payload","item","id","Date","now","Math","random","toString","slice","read","prev","info","title","disconnect","unreadCount","filter","length","markAllRead","map","Provider","value","useNotifications"],"sources":["D:/web developer/salon-management/salon-management/frontend/src/context/NotificationContext.js"],"sourcesContent":["import React, { createContext, useContext, useEffect, useMemo, useState } from 'react';\nimport { io } from 'socket.io-client';\nimport { toast } from 'react-toastify';\nimport { useAuth } from './AuthContext';\n\nconst NotificationContext = createContext();\n\nexport const NotificationProvider = ({ children }) => {\n  const { user } = useAuth();\n  const [notifications, setNotifications] = useState([]);\n\n  useEffect(() => {\n    if (!user || user.role === 'customer') {\n      setNotifications([]);\n      return undefined;\n    }\n\n    const socket = io(process.env.REACT_APP_SOCKET_URL || 'http://localhost:5000', {\n      transports: ['websocket', 'polling']\n    });\n\n    socket.on('notification', (payload) => {\n      const item = {\n        id: `${Date.now()}-${Math.random().toString(36).slice(2, 7)}`,\n        read: false,\n        ...payload\n      };\n\n      setNotifications((prev) => [item, ...prev].slice(0, 30));\n      toast.info(payload.title || 'New notification');\n    });\n\n    return () => socket.disconnect();\n  }, [user]);\n\n  const unreadCount = useMemo(\n    () => notifications.filter((item) => !item.read).length,\n    [notifications]\n  );\n\n  const markAllRead = () =>\n    setNotifications((prev) => prev.map((item) => ({ ...item, read: true })));\n\n  return (\n    <NotificationContext.Provider value={{ notifications, unreadCount, markAllRead }}>\n      {children}\n    </NotificationContext.Provider>\n  );\n};\n\nexport const useNotifications = () => useContext(NotificationContext);\n"],"mappings":"AAAA,MAAO,CAAAA,KAAK,EAAIC,aAAa,CAAEC,UAAU,CAAEC,SAAS,CAAEC,OAAO,CAAEC,QAAQ,KAAQ,OAAO,CACtF,OAASC,EAAE,KAAQ,kBAAkB,CACrC,OAASC,KAAK,KAAQ,gBAAgB,CACtC,OAASC,OAAO,KAAQ,eAAe,CAAC,OAAAC,GAAA,IAAAC,IAAA,yBAExC,KAAM,CAAAC,mBAAmB,cAAGV,aAAa,CAAC,CAAC,CAE3C,MAAO,MAAM,CAAAW,oBAAoB,CAAGC,IAAA,EAAkB,IAAjB,CAAEC,QAAS,CAAC,CAAAD,IAAA,CAC/C,KAAM,CAAEE,IAAK,CAAC,CAAGP,OAAO,CAAC,CAAC,CAC1B,KAAM,CAACQ,aAAa,CAAEC,gBAAgB,CAAC,CAAGZ,QAAQ,CAAC,EAAE,CAAC,CAEtDF,SAAS,CAAC,IAAM,CACd,GAAI,CAACY,IAAI,EAAIA,IAAI,CAACG,IAAI,GAAK,UAAU,CAAE,CACrCD